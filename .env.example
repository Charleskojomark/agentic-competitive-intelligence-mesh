# ==============================================================================
# Production Multi-Agent Competitive Intelligence System - Configuration
# ==============================================================================
# Copy this file to .env and configure the variables for local development.
# Reference: docker-compose.yml contains the docker network routing variables.

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# Local SQLite default or remote/Docker PostgreSQL database connection URL
DATABASE_URL=sqlite:///./agent_tasks.db
# For production/Docker: postgresql://postgres:password123@localhost:5432/agent_db

# ------------------------------------------------------------------------------
# 2. Redis Message Broker & State Configuration
# ------------------------------------------------------------------------------
# Connection string for Redis (used for distributed circuit breaking & tasks)
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# 3. LLM Provider (Groq Cloud API)
# ------------------------------------------------------------------------------
# Get your API key from https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# LLM model choices (e.g., llama-3.3-70b-versatile, llama3-8b-8192, etc.)
LLM_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------------------------
# 4. Observability & Telemetry (Langfuse)
# ------------------------------------------------------------------------------
# Obtain these from your Langfuse project settings dashboard
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://localhost:3000

# ------------------------------------------------------------------------------
# 5. Agent-to-Agent (A2A) Discovery & Routing URLs
# ------------------------------------------------------------------------------
# Local development base URLs for individual microservices.
# (If running services locally, these are the ports they bind to)
INGESTION_AGENT_URL=http://localhost:8001/api/v1/agent
ANALYSIS_AGENT_URL=http://localhost:8002/api/v1/agent
REPORTING_AGENT_URL=http://localhost:8003/api/v1/agent
ALERT_AGENT_URL=http://localhost:8004/api/v1/agent
